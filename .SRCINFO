	depends = libpulse
	depends = ydotool
	depends = curl
	optdepends = cuda: build/run with GPU-accelerated sherpa-onnx
	optdepends = cudnn: required with cuda for GPU builds
	optdepends = python-sentencepiece: encode custom KWS keywords at install/runtime
	optdepends = nvidia-utils: NVIDIA driver userspace for CUDA
	options = !debug
	source = willow::git+https://github.com/Saim20/willow.git#tag=v3.0.0
	sha256sums = SKIP

pkgname = willow

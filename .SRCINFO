pkgbase = willow
	pkgdesc = Simple offline configurable voice assistant for gnome
	pkgver = 3.0.0
	pkgrel = 5
	url = https://github.com/Saim20/willow
	install = willow.install
	arch = x86_64
	license = MIT
	makedepends = rust
	makedepends = cargo
	makedepends = glib2
	makedepends = bzip2
